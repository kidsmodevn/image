{
  "manifest_version": 3,
  "name": "Blogger Uploader Pro",
  "version": "1.0",
  "description": "Tiện ích upload ảnh hàng loạt lên ImgBB và trích xuất album Facebook cho Blogger",
  "action": {
    "default_popup": "index.html",
    "default_title": "Blogger Uploader Pro"
  },
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://*.facebook.com/*",
    "https://api.imgbb.com/*"
  ]
}
